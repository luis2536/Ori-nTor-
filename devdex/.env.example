# DevDex - Environment Configuration Example
PORT=5000
NODE_ENV=development

# Security Configuration
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Secret Key (Use a strong unique key in production)
JWT_SECRET=super_secret_devdex_token_key_here
